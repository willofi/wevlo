{
  "name": "wevlo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:contracts": "turbo run test:contracts",
    "test:e2e": "turbo run test:e2e",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "WEVLO_ENV_FILE=apps/api/.env.local pnpm --filter @wevlo/data-access migrate",
    "qa:check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "5.9.3",
    "vitest": "latest"
  }
}
