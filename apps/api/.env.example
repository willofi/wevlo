PORT=4000

DATABASE_URL=postgres://wevlo:wevlo@127.0.0.1:5432/wevlo
ALLOW_DEV_AUTH=true
WEVLO_DEV_USER_ID=user_demo_owner
WEVLO_INTERNAL_AUTH_TOKEN=wevlo-internal-dev-token

WEVLO_STORAGE_DRIVER=local
WEVLO_ATTACHMENT_STORAGE_DIR=.wevlo/attachments

# Optional when WEVLO_STORAGE_DRIVER=supabase_s3
WEVLO_S3_ENDPOINT=
WEVLO_S3_REGION=
WEVLO_S3_BUCKET=
WEVLO_S3_ACCESS_KEY_ID=
WEVLO_S3_SECRET_ACCESS_KEY=
