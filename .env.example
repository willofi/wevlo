# Local development: copy this file to `.env.local`.
# Deployment server: copy this file to `.env.production`.

# Shared (web + api)
# Production should be false.
ALLOW_DEV_AUTH=true
WEVLO_DEV_USER_ID=user_demo_owner
WEVLO_INTERNAL_AUTH_TOKEN=wevlo-internal-dev-token
WEVLO_API_BASE_URL=http://127.0.0.1:4000

# API / worker
DATABASE_URL=postgres://wevlo:wevlo@127.0.0.1:5432/wevlo
WEVLO_STORAGE_DRIVER=local
WEVLO_ATTACHMENT_STORAGE_DIR=
WEVLO_S3_ENDPOINT=
WEVLO_S3_REGION=
WEVLO_S3_ACCESS_KEY_ID=
WEVLO_S3_SECRET_ACCESS_KEY=
WEVLO_S3_BUCKET=

# Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_DEV_USER_ID=user_demo_owner
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=replace-me-with-a-long-random-string
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Local Postgres (docker compose)
POSTGRES_USER=wevlo
POSTGRES_PASSWORD=wevlo
POSTGRES_DB=wevlo
