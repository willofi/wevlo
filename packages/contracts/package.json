{
  "name": "@wevlo/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "zod": "catalog:"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/fix-dist-esm-specifiers.mjs dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:contracts": "vitest run src/**/*.test.ts",
    "test:e2e": "vitest run --passWithNoTests"
  }
}
