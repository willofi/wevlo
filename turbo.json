{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        ".expo/**",
        "src-tauri/target/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build",
        "^test"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": [
        "^test:unit"
      ],
      "outputs": []
    },
    "test:contracts": {
      "dependsOn": [
        "^test:contracts"
      ],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": [
        "^test:e2e"
      ],
      "outputs": []
    }
  }
}
